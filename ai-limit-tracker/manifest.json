{
  "manifest_version": 3,
  "name": "AI Limit Tracker",
  "version": "1.0.0",
  "description": "Monitor message limits, reset timers, and usage across Claude, ChatGPT, Gemini, Copilot, Grok, Perplexity, and more.",
  "permissions": ["storage", "alarms", "notifications", "tabs", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://grok.x.com/*",
    "https://x.com/*",
    "https://www.perplexity.ai/*",
    "https://www.meta.ai/*",
    "https://chat.mistral.ai/*",
    "https://you.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Limit Tracker",
    "default_icon": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-limit-tracker@jojin.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": false
    },
    "gecko_android": {
      "id": "ai-limit-tracker@jojin.local"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://grok.x.com/*",
        "https://www.perplexity.ai/*",
        "https://www.meta.ai/*",
        "https://chat.mistral.ai/*",
        "https://you.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
